{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vivestream-next",
  "version": "0.3.0",
  "identifier": "com.localghost.vivestream-next",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vivestream-next",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["/home/localghost/Videos/ViveStream/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}