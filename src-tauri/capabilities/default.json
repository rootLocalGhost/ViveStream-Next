{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "/home/localghost/Videos/ViveStream/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "/home/localghost/Videos/ViveStream/**" }]
    }
  ]
}